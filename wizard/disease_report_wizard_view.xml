<odoo>
    <record id="view_disease_report_wizard_form" model="ir.ui.view">
        <field name="name">disease.report.wizard.form</field>
        <field name="model">disease.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Параметри звіту">
                <group>
                    <group string="Період">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group string="Фільтри">
                        <field name="doctor_ids" widget="many2many_tags" placeholder="Всі лікарі..."/>
                        <field name="disease_ids" widget="many2many_tags" placeholder="Всі хвороби..."/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_report" string="Сформувати" type="object" class="btn-primary"/>
                    <button string="Скасувати" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_disease_report_wizard_doctor" model="ir.actions.act_window">
        <field name="name">Звіт по хворобах</field>
        <field name="res_model">disease.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hr_hospital_doctor"/>
        <field name="binding_type">report</field>
    </record>
</odoo>

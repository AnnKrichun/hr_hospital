<odoo>
    <record id="view_visit_report_wizard_form" model="ir.ui.view">
        <field name="name">visit.report.wizard.form</field>
        <field name="model">visit.report.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="doctor_ids" widget="many2many_tags"/>
                        <field name="patient_ids" widget="many2many_tags"/>
                        <field name="disease_id"/>
                    </group>
                    <group>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="done_only"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_report" string="Сформувати" type="object" class="btn-primary"/>
                    <button string="Скасувати" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_visit_report_from_patient" model="ir.actions.act_window">
        <field name="name">Сформувати звіт по візитах</field>
        <field name="res_model">visit.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hr_hospital_patient"/>
    </record>

    <record id="action_visit_report_from_doctor" model="ir.actions.act_window">
        <field name="name">Сформувати звіт по візитах</field>
        <field name="res_model">visit.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hr_hospital_doctor"/>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    <!-- Лікарі -->
    <record id="doctor_1" model="hr.hospital.doctor">
        <field name="name">Д-р Григорій Хаус</field>
        <field name="specialization">Діагностика</field>
    </record>

    <record id="doctor_2" model="hr.hospital.doctor">
        <field name="name">Д-р Джон Ватсон</field>
        <field name="specialization">Терапія</field>
    </record>

    <record id="doctor_3" model="hr.hospital.doctor">
        <field name="name">Д-р Стівен Стренж</field>
        <field name="specialization">Нейрохирургія</field>
    </record>

    <record id="doctor_4" model="hr.hospital.doctor">
        <field name="name">Д-р Албан</field>
        <field name="specialization">Терапевт</field>
    </record>

    <!-- Пацієнти -->
    <record id="patient_1" model="hr.hospital.patient">
        <field name="name">Іван Іваненко</field>
        <field name="birthday">1990-05-15</field>
        <field name="personal_doctor_id" ref="doctor_1"/>
    </record>

    <record id="patient_2" model="hr.hospital.patient">
        <field name="name">Марія Петренко</field>
        <field name="birthday">1985-11-20</field>
        <field name="personal_doctor_id" ref="doctor_2"/>
    </record>

    <record id="patient_3" model="hr.hospital.patient">
        <field name="name">Олексій Сидоренко</field>
        <field name="birthday">2000-01-10</field>
        <field name="personal_doctor_id" ref="doctor_1"/>
    </record>

    <record id="visit_1" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_1"/>
        <field name="personal_doctor_id" ref="doctor_1"/>
        <field name="planned_date" eval="(datetime.now() - timedelta(days=1)).strftime('%Y-%m-%d 10:00:00')"/>
        <field name="visit_date" eval="(datetime.now() - timedelta(days=1)).strftime('%Y-%m-%d 10:15:00')"/>
        <field name="state">done</field>
        <field name="summary"><![CDATA[<p>Пацієнт здоровий.</p>]]></field>
    </record>

    <record id="visit_2" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_2"/>
        <field name="personal_doctor_id" ref="doctor_2"/>
        <field name="planned_date" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 09:00:00')"/>
        <field name="state">planned</field>
    </record>

    <record id="visit_3" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_1"/>
        <field name="personal_doctor_id" ref="doctor_2"/>
        <field name="planned_date" eval="(datetime.now() - timedelta(days=2)).strftime('%Y-%m-%d 12:00:00')"/>
        <field name="visit_date" eval="(datetime.now() - timedelta(days=2)).strftime('%Y-%m-%d 12:30:00')"/>
        <field name="state">done</field>
        <field name="summary"><![CDATA[<p>Повторний огляд.</p>]]></field>
    </record>

    <record id="visit_4" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_3"/>
        <field name="personal_doctor_id" ref="doctor_1"/>
        <field name="planned_date" eval="(datetime.now() + timedelta(days=2)).strftime('%Y-%m-%d 11:00:00')"/>
        <field name="state">planned</field>
    </record>

    <record id="visit_5" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_3"/>
        <field name="personal_doctor_id" ref="doctor_4"/>
        <field name="planned_date" eval="(datetime.now() - timedelta(days=3)).strftime('%Y-%m-%d 09:00:00')"/>
        <field name="visit_date" eval="(datetime.now() - timedelta(days=3)).strftime('%Y-%m-%d 09:20:00')"/>
        <field name="state">done</field>
        <field name="summary"><![CDATA[<p>Скарги відсутні.</p>]]></field>
    </record>

    <record id="visit_6" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_2"/>
        <field name="personal_doctor_id" ref="doctor_3"/>
        <field name="planned_date" eval="(datetime.now() + timedelta(days=3)).strftime('%Y-%m-%d 15:00:00')"/>
        <field name="state">planned</field>
    </record>

    <record id="visit_demo_1" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_1"/>
        <field name="personal_doctor_id" ref="doctor_1"/>
        <field name="disease_id" ref="disease_item_covid"/>
        <field name="planned_date" eval="(datetime.now() - relativedelta(days=5)).strftime('%Y-%m-%d 10:00:00')"/>
        <field name="visit_date" eval="(datetime.now() - relativedelta(days=5)).strftime('%Y-%m-%d 10:15:00')"/>
        <field name="state">done</field>
        <field name="summary">Пацієнт скаржився на температуру. Призначено спокій.</field>
    </record>

    <record id="visit_demo_2" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_2"/>
        <field name="personal_doctor_id" ref="doctor_2"/>
        <field name="planned_date" eval="datetime.now().strftime('%Y-%m-%d 14:00:00')"/>
        <field name="state">planned</field>
    </record>

    <record id="visit_demo_3" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_1"/>
        <field name="personal_doctor_id" ref="doctor_2"/>
        <field name="planned_date" eval="(datetime.now() + relativedelta(days=1)).strftime('%Y-%m-%d 09:00:00')"/>
        <field name="state">planned</field>
    </record>

    <record id="visit_demo_4" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_3"/>
        <field name="personal_doctor_id" ref="doctor_1"/>
        <field name="planned_date" eval="(datetime.now() - relativedelta(days=2)).strftime('%Y-%m-%d 16:30:00')"/>
        <field name="state">cancelled</field>
        <field name="treatment_notes">Пацієнт не з'явився на прийом.</field>
    </record>

    <record id="visit_demo_5" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_1"/>
        <field name="personal_doctor_id" ref="doctor_2"/>
        <field name="planned_date" eval="(datetime.now() - relativedelta(days=3)).strftime('%Y-%m-%d 16:30:00')"/>
        <field name="state">done</field>
        <field name="treatment_notes">Пацієнт скаржиться на біль у животі.</field>
    </record>

    <record id="visit_demo_6" model="hr.hospital.visit">
        <field name="patient_id" ref="patient_3"/>
        <field name="personal_doctor_id" ref="doctor_3"/>
        <field name="planned_date" eval="(datetime.now() - relativedelta(days=2)).strftime('%Y-%m-%d 16:30:00')"/>
        <field name="state">done</field>
        <field name="treatment_notes">Пацієнт скаржиться на головний біль.</field>
    </record>

    </data>
 </odoo>

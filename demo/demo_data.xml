<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Doctors -->
        <record id="doctor_1" model="hr.hospital.doctor">
            <field name="name">Dr. Gregory House</field>
            <field name="specialization">Diagnostics</field>
            <field name="category_id" ref="doctor_category_senior"/>
        </record>

        <record id="doctor_2" model="hr.hospital.doctor">
            <field name="name">Dr. John Watson</field>
            <field name="specialization">Therapy</field>
            <field name="category_id" ref="doctor_category_specialist"/>
        </record>

        <record id="doctor_3" model="hr.hospital.doctor">
            <field name="name">Dr. Stephen Strange</field>
            <field name="specialization">Neurosurgery</field>
            <field name="category_id" ref="doctor_category_senior"/>
        </record>

        <record id="doctor_4" model="hr.hospital.doctor">
            <field name="name">Dr. Alban</field>
            <field name="specialization">General Practitioner</field>
            <field name="category_id" ref="doctor_category_intern"/>
        </record>

        <!-- Patients -->
        <record id="patient_1" model="hr.hospital.patient">
            <field name="name">Ivan Ivanenko</field>
            <field name="birthday">1990-05-15</field>
            <field name="personal_doctor_id" ref="doctor_1"/>
        </record>

        <record id="patient_2" model="hr.hospital.patient">
            <field name="name">Maria Petrenko</field>
            <field name="birthday">1985-11-20</field>
            <field name="personal_doctor_id" ref="doctor_2"/>
        </record>

        <record id="patient_3" model="hr.hospital.patient">
            <field name="name">Oleksii Sydorenko</field>
            <field name="birthday">2000-01-10</field>
            <field name="personal_doctor_id" ref="doctor_1"/>
        </record>

        <!-- Visits -->
        <record id="visit_1" model="hr.hospital.visit">
            <field name="patient_id" ref="patient_1"/>
            <field name="personal_doctor_id" ref="doctor_1"/>
            <field name="planned_date" eval="(datetime.now() - timedelta(days=1)).strftime('%Y-%m-%d 10:00:00')"/>
            <field name="visit_date" eval="(datetime.now() - timedelta(days=1)).strftime('%Y-%m-%d 10:15:00')"/>
            <field name="state">done</field>
            <field name="summary"><![CDATA[<p>Patient is healthy.</p>]]></field>
        </record>

        <record id="visit_2" model="hr.hospital.visit">
            <field name="patient_id" ref="patient_2"/>
            <field name="personal_doctor_id" ref="doctor_2"/>
            <field name="planned_date" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 09:00:00')"/>
            <field name="state">planned</field>
        </record>

        <record id="visit_demo_1" model="hr.hospital.visit">
            <field name="patient_id" ref="patient_1"/>
            <field name="personal_doctor_id" ref="doctor_1"/>
            <field name="disease_id" ref="disease_item_covid"/>
            <field name="planned_date" eval="(datetime.now() - timedelta(days=5)).strftime('%Y-%m-%d 10:00:00')"/>
            <field name="visit_date" eval="(datetime.now() - timedelta(days=5)).strftime('%Y-%m-%d 10:15:00')"/>
            <field name="state">done</field>
            <field name="summary">Patient complained of fever. Rest prescribed.</field>
        </record>

        <record id="visit_demo_4" model="hr.hospital.visit">
            <field name="patient_id" ref="patient_3"/>
            <field name="personal_doctor_id" ref="doctor_1"/>
            <field name="planned_date" eval="(datetime.now() - timedelta(days=2)).strftime('%Y-%m-%d 16:30:00')"/>
            <field name="state">cancelled</field>
            <field name="treatment_notes">Patient did not show up for the appointment.</field>
        </record>

        <record id="visit_demo_5" model="hr.hospital.visit">
            <field name="patient_id" ref="patient_1"/>
            <field name="personal_doctor_id" ref="doctor_2"/>
            <field name="planned_date" eval="(datetime.now() - timedelta(days=3)).strftime('%Y-%m-%d 16:30:00')"/>
            <field name="state">done</field>
            <field name="treatment_notes">Patient complains of abdominal pain.</field>
        </record>

    </data>
</odoo>

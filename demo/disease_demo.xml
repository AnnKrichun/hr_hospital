<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Root Categories -->
        <record id="cat_infectious" model="hr.hospital.disease">
            <field name="name">Infectious Diseases</field>
        </record>

        <record id="cat_cardiology" model="hr.hospital.disease">
            <field name="name">Cardiology</field>
        </record>

        <!-- Infectious Diseases Sub-items -->
        <record id="disease_flu" model="hr.hospital.disease">
            <field name="name">Influenza (Flu)</field>
            <field name="parent_id" ref="cat_infectious"/>
        </record>

        <record id="disease_covid" model="hr.hospital.disease">
            <field name="name">COVID-19</field>
            <field name="parent_id" ref="cat_infectious"/>
        </record>

        <!-- Cardiology Sub-items -->
        <record id="disease_hypertension" model="hr.hospital.disease">
            <field name="name">Hypertension</field>
            <field name="parent_id" ref="cat_cardiology"/>
        </record>

        <record id="disease_arrhythmia" model="hr.hospital.disease">
            <field name="name">Arrhythmia</field>
            <field name="parent_id" ref="cat_cardiology"/>
        </record>

        <!-- Other Diseases -->
        <record id="disease_bronchitis" model="hr.hospital.disease">
            <field name="name">Acute Bronchitis</field>
        </record>

        <record id="disease_gastritis" model="hr.hospital.disease">
            <field name="name">Gastritis</field>
        </record>

        <record id="disease_diabetes" model="hr.hospital.disease">
            <field name="name">Type 2 Diabetes</field>
        </record>

    </data>
</odoo>

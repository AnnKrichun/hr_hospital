<odoo>
    <data>

        <record id="view_hr_hospital_doctor_list" model="ir.ui.view">
            <field name="name">hr.hospital.doctor.list</field>
            <field name="model">hr.hospital.doctor</field>
            <field name="arch" type="xml">
                <list string="Лікарі">
                    <field name="name"/>
                    <field name="specialization"/>
                    <field name="category_id"/>
                    <field name="is_intern" string="Інтерн"/>
                    <field name="mentor_id"
                        invisible="not is_intern"
                        required="is_intern"/>
                </list>
            </field>
        </record>

        <record id="view_hr_hospital_doctor_form" model="ir.ui.view">
            <field name="name">hr.hospital.doctor.form</field>
            <field name="model">hr.hospital.doctor</field>
            <field name="arch" type="xml">
                <form string="Лікар">
                    <sheet>

                        <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>

                        <div class="oe_title">
                            <h1><field name="name" placeholder="ПІБ Лікаря"/></h1>
                        </div>

                        <group>
                            <group string="Основна інформація">
                                <field name="name"/>
                                <field name="specialization"/>
                                <field name="category_id"/>
                                <field name="user_id"/>
                            </group>
                            <group string="Медичні дані">
                                <field name="gender"/>
                                <field name="birthday"/>
                                <field name="age"/>
                                <field name="blood_type"/>
                            </group>
                        </group>

                        <group string="Статус та наставництво">
                            <field name="is_intern"/>
                            <field name="mentor_id"
                                   invisible="not is_intern"
                                   required="is_intern"
                                   domain="[('is_intern', '=', False), ('id', '!=', id)]"/>
                        </group>

                        <notebook>
                        <page string="Інтерни" name="page_interns" invisible="is_intern">
                            <field name="intern_ids" mode="kanban" readonly="1">
                                <kanban>
                                    <templates>
                                        <t t-name="card">
                                            <div class="d-flex">
                                            <div class="me-3">
                                                <field name="image_128" widget="image" class="o_image_64_max" options="{'zoom': true}"/>
                                            </div>
                                            <div class="flex-grow-1">
                                            <div class="fw-bold fs-5">
                                                <field name="name"/>
                                            </div>
                                            <div class="text-muted">
                                                <field name="specialization"/>
                                            </div>
                                            </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                        </notebook>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hr_hospital_doctor_search" model="ir.ui.view">
            <field name="name">hr.hospital.doctor.search</field>
            <field name="model">hr.hospital.doctor</field>
            <field name="arch" type="xml">
            <search string="Пошук лікарів">
                <field name="name"/>
                <field name="specialization"/>
                <field name="category_id"/>

                <separator/>

                <filter string="Інтерни" name="filter_interns" domain="[('is_intern', '=', True)]"/>
                <filter string="Ментори" name="filter_mentors" domain="[('is_intern', '=', False)]"/>

                <separator/>

                <group>
                    <filter string="Спеціалізація" name="group_by_specialization" context="{'group_by': 'specialization'}"/>
                    <filter string="Категорія" name="group_by_category" context="{'group_by': 'category_id'}"/>
                </group>
            </search>
            </field>
        </record>

        <record id="view_hr_hospital_doctor_kanban" model="ir.ui.view">
            <field name="name">hr.hospital.doctor.kanban</field>
            <field name="model">hr.hospital.doctor</field>
            <field name="arch" type="xml">
            <kanban default_group_by="specialization" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="specialization"/>
                <field name="image_128"/>
                <templates>
                <t t-name="card">
                    <div class="oe_kanban_global_click d-flex align-items-center">
                        <div class="me-3">
                            <field name="image_128" widget="image" class="o_image_64_max"/>
                        </div>
                        <div class="flex-grow-1">
                            <strong class="o_kanban_record_title"><field name="name"/></strong>
                            <div class="text-muted"><field name="specialization"/></div>
                            <button name="action_create_appointment"
                                    type="object"
                                    class="btn btn-primary btn-sm mt-2">
                                    Записати пацієнта
                            </button>
                        </div>
                    </div>
                </t>
                </templates>
            </kanban>
            </field>
        </record>

        <record id="action_hr_hospital_doctor" model="ir.actions.act_window">
            <field name="name">Лікарі</field>
            <field name="res_model">hr.hospital.doctor</field>
            <field name="view_mode">kanban,list,form</field>
        </record>

        <menuitem id="menu_hr_hospital_doctor"
          name="Doctors"
          parent="hr_hospital.menu_hr_hospital_operations"
          action="action_hr_hospital_doctor"
          sequence="20"/>
    </data>
</odoo>


<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search View -->
    <record id="view_hr_hospital_disease_search" model="ir.ui.view">
        <field name="name">hr.hospital.disease.search</field>
        <field name="model">hr.hospital.disease</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="parent_id"/>
                <filter string="Main Categories" name="root_only" domain="[('parent_id', '=', False)]"/>

                <searchpanel>
                    <field name="parent_id"
                           string="Categories"
                           icon="fa-folder"
                           enable_counters="1"
                           hierarchical="1"
                           expand="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="view_hr_hospital_disease_list" model="ir.ui.view">
        <field name="name">hr.hospital.disease.list</field>
        <field name="model">hr.hospital.disease</field>
        <field name="arch" type="xml">
            <list string="Diseases">
                <field name="display_name"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hr_hospital_disease_form" model="ir.ui.view">
        <field name="name">hr.hospital.disease.form</field>
        <field name="model">hr.hospital.disease</field>
        <field name="arch" type="xml">
            <form string="Disease">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id" domain="[('id', '!=', id)]" options="{'no_create': True}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_hospital_disease" model="ir.actions.act_window">
        <field name="name">Diseases</field>
        <field name="res_model">hr.hospital.disease</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record a new disease type
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_hr_hospital_disease"
              name="Diseases"
              parent="menu_hr_hospital_operations"
              action="action_hr_hospital_disease"
              sequence="30"/>

</odoo>

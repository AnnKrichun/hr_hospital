<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_hospital_disease_search" model="ir.ui.view">
        <field name="name">hr.hospital.disease.search</field>
        <field name="model">hr.hospital.disease</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="parent_id"/>
                <filter string="Головні категорії" name="root_only" domain="[('parent_id', '=', False)]"/>
            <searchpanel>
                <field name="parent_id"
                       string="Категорії"
                       icon="fa-folder"
                       enable_counters="1"
                       expand="1"/>
            </searchpanel>
            </search>
        </field>
    </record>

    <record id="view_hr_hospital_disease_list" model="ir.ui.view">
        <field name="name">hr.hospital.disease.list</field>
        <field name="model">hr.hospital.disease</field>
        <field name="arch" type="xml">
            <list string="Захворювання">
                <field name="display_name"/>
            </list>
        </field>
    </record>

    <record id="view_hr_hospital_disease_form" model="ir.ui.view">
        <field name="name">hr.hospital.disease.form</field>
        <field name="model">hr.hospital.disease</field>
        <field name="arch" type="xml">
            <form string="Захворювання">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id" domain="[('id', '!=', id)]"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_hospital_disease" model="ir.actions.act_window">
        <field name="name">Захворювання</field>
        <field name="res_model">hr.hospital.disease</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_hospital_disease"
              name="Types of diseases"
              parent="menu_hr_hospital_operations"
              action="action_hr_hospital_disease"
              sequence="30"/>
</odoo>

<odoo>
    <data>
        <record id="view_hr_hospital_visit_list" model="ir.ui.view">
            <field name="name">hr.hospital.visit.list</field>
            <field name="model">hr.hospital.visit</field>
            <field name="arch" type="xml">
                <list string="Visits"
                      decoration-info="state == 'planned'"
                      decoration-success="state == 'done'"
                      decoration-muted="state == 'cancelled'">
                    <field name="visit_date"/>
                    <field name="patient_id"/>
                    <field name="personal_doctor_id"/>
                    <field name="disease_id"/>
                    <field name="state" widget="badge"
                           decoration-info="state == 'planned'"
                           decoration-success="state == 'done'"/>
                </list>
            </field>
        </record>

        <record id="action_hr_hospital_visit" model="ir.actions.act_window">
            <field name="name">Visits</field>
            <field name="res_model">hr.hospital.visit</field>
            <field name="view_mode">calendar,list,graph,pivot,form</field>
            <field name="context">{'search_default_this_month': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Schedule a new visit</p>
            </field>
        </record>

        <record id="view_hr_hospital_visit_form" model="ir.ui.view">
            <field name="name">hr.hospital.visit.form</field>
            <field name="model">hr.hospital.visit</field>
            <field name="arch" type="xml">
                <form string="Visit">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="planned,done,cancelled" options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="%(action_hr_hospital_visit)d"
                                    type="action"
                                    class="oe_stat_button"
                                    icon="fa-stethoscope"
                                    context="{'search_default_disease_id': disease_id, 'default_disease_id': disease_id}">
                                <div class="o_stat_info">
                                    <span class="o_stat_text">Similar Cases</span>
                                </div>
                            </button>
                        </div>

                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>

                        <group>
                            <group string="Main Information" name="main_info">
                                <field name="patient_id" readonly="state == 'done'" options="{'no_create': True}"/>
                                <field name="personal_doctor_id" readonly="state == 'done'" options="{'no_create': True}"/>
                                <field name="disease_id" readonly="state == 'done'" placeholder="Select diagnosis..." options="{'no_create': True}"/>
                            </group>
                            <group string="Scheduling &amp; Status" name="scheduling">
                                <field name="planned_date" readonly="state == 'done'"/>
                                <field name="visit_date" readonly="state == 'done'"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Clinical Summary" name="page_summary">
                                <group>
                                    <separator string="Medical Conclusion (Summary)"/>
                                    <field name="summary" nolabel="1" placeholder="Describe symptoms, exam results..."/>
                                </group>
                            </page>
                            <page string="Treatment &amp; Advice" name="page_treatment">
                                <group>
                                    <separator string="Treatment Plan &amp; Recommendations"/>
                                    <field name="treatment_notes" nolabel="1" placeholder="Specify medications, procedures..."/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hr_hospital_visit_calendar" model="ir.ui.view">
            <field name="name">hr.hospital.visit.calendar</field>
            <field name="model">hr.hospital.visit</field>
            <field name="arch" type="xml">
                <calendar date_start="planned_date" color="personal_doctor_id" mode="month" quick_create="0" event_open_popup="true">
                    <field name="patient_id"/>
                    <field name="personal_doctor_id" filters="1"/>
                    <field name="state" filters="1"/>
                </calendar>
            </field>
        </record>

        <record id="view_hr_hospital_visit_search" model="ir.ui.view">
            <field name="name">hr.hospital.visit.search</field>
            <field name="model">hr.hospital.visit</field>
            <field name="arch" type="xml">
                <search>
                    <field name="patient_id"/>
                    <field name="personal_doctor_id"/>
                    <field name="disease_id"/>

                    <searchpanel>
                        <field name="personal_doctor_id"
                            string="Doctor"
                            icon="fa-user-md"
                            enable_counters="1"
                            select="multi"/>
                        <field name="disease_id"
                            string="Diagnosis"
                            icon="fa-heartbeat"
                            enable_counters="1"
                            select="multi"/>
                    </searchpanel>

                    <filter string="Planned" name="planned" domain="[('state', '=', 'planned')]"/>
                    <filter string="Completed" name="done" domain="[('state', '=', 'done')]"/>

                    <group>
                        <filter string="Status" name="by_state" context="{'group_by': 'state'}"/>
                        <filter string="Doctor" name="by_doctor" context="{'group_by': 'personal_doctor_id'}"/>
                    </group>

                    <filter string="This Month" name="this_month"
                    domain="[('planned_date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>

                </search>
            </field>
        </record>

        <record id="view_hr_hospital_visit_pivot" model="ir.ui.view">
            <field name="name">hr.hospital.visit.pivot</field>
            <field name="model">hr.hospital.visit</field>
            <field name="arch" type="xml">
                <pivot string="Visits Analysis" sample="1">
                    <field name="personal_doctor_id" type="row"/>
                    <field name="state" type="col"/>
                </pivot>
            </field>
        </record>

        <record id="view_hr_hospital_visit_diagnosis_pivot" model="ir.ui.view">
            <field name="name">hr.hospital.visit.diagnosis.pivot</field>
            <field name="model">hr.hospital.visit</field>
            <field name="arch" type="xml">
                <pivot string="Diagnosis Analysis">
                    <field name="disease_id" type="row"/>
                    <field name="visit_date" interval="year" type="col"/>
                    <field name="visit_date" interval="month" type="col"/>
                </pivot>
            </field>
        </record>
        <record id="view_hr_hospital_visit_graph" model="ir.ui.view">
            <field name="name">hr.hospital.visit.graph</field>
            <field name="model">hr.hospital.visit</field>
            <field name="arch" type="xml">
                <graph string="Monthly Visit Analysis" type="bar" stacked="1" sample="1">
                    <field name="visit_date" interval="month"/>
                    <field name="disease_id"/>
                </graph>
            </field>
        </record>

        <record id="action_hr_hospital_diagnosis_analysis" model="ir.actions.act_window">
            <field name="name">Diagnostics Analytics</field>
            <field name="res_model">hr.hospital.visit</field>
            <field name="view_mode">graph,pivot</field>
            <field name="view_id" ref="view_hr_hospital_visit_graph"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No visit data for analysis yet.
                </p>
            </field>
        </record>

        <menuitem id="menu_hr_hospital_diagnosis_analysis"
                  name="Diagnostics Analytics"
                  parent="menu_hr_hospital_operations"
                  action="action_hr_hospital_diagnosis_analysis"
                  sequence="50"/>

    </data>
</odoo>

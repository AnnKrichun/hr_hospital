<odoo>
    <data noupdate="1">

        <!-- Демо-дані для Лікарів -->
        <record id="doctor_1" model="hr.hospital.doctor">
            <field name="name">Д-р Григорій Хаус</field>
            <field name="specialization">Діагностика</field>
        </record>

        <record id="doctor_2" model="hr.hospital.doctor">
            <field name="name">Д-р Джон Ватсон</field>
            <field name="specialization">Терапія</field>
        </record>

        <record id="doctor_3" model="hr.hospital.doctor">
            <field name="name">Д-р Стівен Стренж</field>
            <field name="specialization">Нейрохірургія</field>
        </record>

        <!-- Демо-дані для Пацієнтів -->
        <record id="patient_1" model="hr.hospital.patient">
            <field name="name">Іван Іваненко</field>
            <field name="birthday">1990-05-15</field>
            <!-- Посилання на лікаря через ref -->
            <field name="doctor_id" ref="doctor_1"/>
        </record>

        <record id="patient_2" model="hr.hospital.patient">
            <field name="name">Марія Петренко</field>
            <field name="birthday">1985-11-20</field>
            <field name="doctor_id" ref="doctor_2"/>
        </record>

        <record id="patient_3" model="hr.hospital.patient">
            <field name="name">Олексій Сидоренко</field>
            <field name="birthday">2000-01-10</field>
            <field name="doctor_id" ref="doctor_1"/>
        </record>

    </data>
</odoo>

<odoo>
    <data noupdate="1">

        <record id="disease_root_infectious" model="hr.hospital.disease">
            <field name="name">Інфекційні захворювання</field>
        </record>

        <record id="disease_sub_viral" model="hr.hospital.disease">
            <field name="name">Вірусні інфекції</field>
            <field name="parent_id" ref="disease_root_infectious"/>
        </record>

        <record id="disease_item_covid" model="hr.hospital.disease">
            <field name="name">COVID-19</field>
            <field name="parent_id" ref="disease_sub_viral"/>
        </record>

        <record id="disease_root_respiratory" model="hr.hospital.disease">
            <field name="name">Захворювання дихальних шляхів</field>
        </record>

        <record id="disease_sub_pneumonia" model="hr.hospital.disease">
            <field name="name">Пневмонія</field>
            <field name="parent_id" ref="disease_root_respiratory"/>
        </record>
    </data>
</odoo>


